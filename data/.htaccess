# Fourge — deny direct HTTP access to sensitive data files.
# users.json: accounts now live in the SQLite database (admin/fourge.db); this
#   file is read ONLY server-side, once, to seed that database on first run.
#   Blocking HTTP access closes the old public exposure of password hashes. You
#   may delete it entirely once your live database has been seeded.
# entries.json: form submissions — visitor names, emails, and phone numbers.
#   The admin reads it through the authenticated API (read_file), never over
#   public HTTP, so nobody should be able to download it.
# Other data/*.json (pages, posts, site, seo) stay readable because the public
# site loads them.
<FilesMatch "^(users|entries)\.json$">
  <IfModule mod_authz_core.c>
    Require all denied
  </IfModule>
  <IfModule !mod_authz_core.c>
    Order allow,deny
    Deny from all
  </IfModule>
</FilesMatch>
